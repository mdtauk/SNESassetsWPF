<Window
    x:Class="SNESassetsWPF.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SNESassetsWPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Settings"
    Width="320"
    Height="400"
    mc:Ignorable="d">


    <Grid>
        <StackPanel Margin="16,12" Orientation="Vertical">
            <TextBlock
                Margin="0,0,0,24"
                Style="{DynamicResource SubtitleTextBlockStyle}"
                Text="Settings" />

            <TextBlock Margin="0,0,0,8" Text="COL PNG export cell size" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="48" />
                </Grid.ColumnDefinitions>


                <Slider
                    IsSnapToTickEnabled="True"
                    Maximum="64"
                    Minimum="8"
                    TickFrequency="4"
                    TickPlacement="BottomRight"
                    Value="{Binding PaletteCellSize}" />

                <TextBlock
                    Grid.Column="1"
                    FontWeight="SemiBold"
                    Text="{Binding PaletteCellSize}"
                    TextAlignment="Right" />

            </Grid>
        </StackPanel>
    </Grid>

</Window>
