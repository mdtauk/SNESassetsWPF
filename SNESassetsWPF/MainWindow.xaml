<Window
    x:Class="SNESassetsWPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:SNESassetsWPF.Helpers"
    xmlns:local="clr-namespace:SNESassetsWPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SNESassetsWPF.Models"
    xmlns:rendering="clr-namespace:SNESassetsWPF.Rendering"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:uc="clr-namespace:SNESassetsWPF.UserControls"
    xmlns:vm="clr-namespace:SNESassetsWPF.ViewModels"
    Title="S-CAD Asset Viewer"
    Width="1280"
    Height="800"
    mc:Ignorable="d">




    <Window.Resources>

        <Style x:Key="listPaletteRowStyle" TargetType="{x:Type ListBoxItem}">
            <!--  Remove default padding/margins  -->
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />

            <!--  Prevent selection when ForceSingleRow = false  -->
            <EventSetter Event="PreviewMouseDown" Handler="PaletteRow_PreviewMouseDown" />

            <!--  Default background  -->
            <Setter Property="Background" Value="Transparent" />

            <!--  Selected background  -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid HorizontalAlignment="Stretch" FocusVisualStyle="{x:Null}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                x:Name="Fcs"
                                Grid.Column="1"
                                Margin="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                BorderThickness="1"
                                Opacity="1"
                                SnapsToDevicePixels="true" />

                            <Border
                                x:Name="Bd"
                                Grid.Column="0"
                                Width="4"
                                Height="16"
                                Background="{DynamicResource AccentFillColorDefaultBrush}" />

                            <ContentPresenter Grid.Column="1" FocusVisualStyle="{x:Null}" />


                        </Grid>

                        <ControlTemplate.Triggers>
                            <!--  Focused  -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Fcs" Property="Opacity" Value="1" />
                            </Trigger>

                            <!--  Selected  -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="1" />
                            </Trigger>

                            <!--  Unselected  -->
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="clearTabs" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="FontWeight" Value="Regular" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
            <Setter Property="KeyboardNavigation.IsTabStop" Value="True" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid x:Name="Root">
                            <Border
                                x:Name="Border"
                                MinHeight="32"
                                Padding="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0">
                                <ContentPresenter
                                    x:Name="ContentSite"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="SelectionStates">
                                    <VisualState x:Name="Unselected" />
                                    <VisualState x:Name="Selected" />
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver" />
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Border"
                                                Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Opacity)"
                                                From="0.0"
                                                To="0.5"
                                                Duration="0:0:.16" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="100" />
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource TabViewItemHeaderBackgroundSelected}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource TabViewSelectedItemBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TabViewItemForegroundSelected}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Path=TabStripPlacement, RelativeSource={RelativeSource AncestorType={x:Type TabControl}}}" Value="Bottom" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1,0,1,1" />
                                <Setter TargetName="Border" Property="CornerRadius" Value="0,0,8,8" />
                            </MultiDataTrigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Path=TabStripPlacement, RelativeSource={RelativeSource AncestorType={x:Type TabControl}}}" Value="Left" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,0,1" />
                                <Setter TargetName="Border" Property="CornerRadius" Value="8,0,0,8" />
                            </MultiDataTrigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Path=TabStripPlacement, RelativeSource={RelativeSource AncestorType={x:Type TabControl}}}" Value="Right" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,0,1" />
                                <Setter TargetName="Border" Property="CornerRadius" Value="0,8,8,0" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>




    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="196" />
            <!--  Tabbed File Tree Column  -->
            <ColumnDefinition Width="auto" />
            <!--  Palette Column  -->
            <ColumnDefinition Width="*" />
            <ColumnDefinition
                Width="160"
                MinWidth="160"
                MaxWidth="592" />
        </Grid.ColumnDefinitions>

        <!--  Menu bar  -->
        <Menu
            Grid.Row="0"
            Grid.ColumnSpan="4"
            HorizontalAlignment="Stretch">
            <MenuItem Header="File">
                <MenuItem
                    x:Name="menuFolderPicker"
                    Command="{Binding DataContext.ChooseFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Header="Open asset folder..." />
            </MenuItem>

            <MenuItem Header="CGX Tools">

                <MenuItem
                    x:Name="menuShowCgxGrid"
                    DataContext="{Binding CgxViewer}"
                    Header="Show CGX Grid"
                    IsCheckable="True"
                    IsChecked="{Binding ShowGrid}"
                    IsEnabled="{Binding IsGridToggleEnabled}" />

                <MenuItem
                    x:Name="menuExportCGXtoPNG"
                    Command="{Binding ExportCgxPngCommand}"
                    Header="Export CGX to PNG" />

            </MenuItem>

            <MenuItem Header="SCR Tools">

                <MenuItem
                    x:Name="menuShowScrGrid"
                    DataContext="{Binding ScrViewer}"
                    Header="Show SCR Grid"
                    IsCheckable="True"
                    IsChecked="{Binding ShowGrid}"
                    IsEnabled="{Binding IsGridToggleEnabled}" />

                <MenuItem
                    x:Name="menuExportSCRtoPNG"
                    Command="{Binding ExportScrPngCommand}"
                    Header="Export SCR to PNG" />

            </MenuItem>

        </Menu>

        <!--  Tabs to switch the loaded file list type  -->
        <TabControl Grid.Row="1" Margin="8,0,12,8">
            <!--  TAB ITEM FOR COL FILES  -->
            <TabItem Header="COL files" Style="{DynamicResource clearTabs}">
                <Border
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <TreeView
                            x:Name="colTreeView"
                            ItemsSource="{Binding ColTree.RootItems}"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItemChanged="colTreeView_SelectedItemChanged">

                            <TreeView.Resources>

                                <!--  Folder template  -->
                                <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}" ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Name}" />
                                </HierarchicalDataTemplate>

                                <!--  File template  -->
                                <DataTemplate DataType="{x:Type models:FileNode}">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>

                            </TreeView.Resources>

                        </TreeView>


                    </Grid>
                </Border>
            </TabItem>

            <!--  TAB ITEM FOR CGX FILES  -->
            <TabItem Header="CGX files" Style="{DynamicResource clearTabs}">
                <Border
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <TreeView
                            x:Name="cgxTreeView"
                            Grid.Row="0"
                            ItemsSource="{Binding CgxTree.RootItems}"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItemChanged="cgxTreeView_SelectedItemChanged">

                            <TreeView.Resources>

                                <!--  Folder template  -->
                                <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}" ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Name}" />
                                </HierarchicalDataTemplate>

                                <!--  File template  -->
                                <DataTemplate DataType="{x:Type models:FileNode}">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>

                            </TreeView.Resources>

                        </TreeView>

                        <Rectangle
                            Grid.Row="1"
                            Height="1"
                            Margin="4,0,4,-1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Fill="{DynamicResource DividerStrokeColorDefaultBrush}"
                            RadiusX="0.5"
                            RadiusY="0.5" />

                        <ComboBox
                            x:Name="comboBPP"
                            Grid.Row="1"
                            Margin="8,12,8,8"
                            SelectedValue="{Binding CgxViewer.BitDepthOverride, Mode=TwoWay}"
                            SelectedValuePath="Tag">
                            <ComboBoxItem Content="2 bpp" Tag="2" />
                            <ComboBoxItem Content="4 bpp" Tag="4" />
                            <ComboBoxItem Content="8 bpp" Tag="8" />
                        </ComboBox>

                    </Grid>
                </Border>
            </TabItem>
        </TabControl>



        <!--  For resizing the tabebd column  -->
        <GridSplitter
            Grid.Row="1"
            Grid.Column="0"
            Width="4"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch" />




        <!--  COL region  -->
        <ScrollViewer
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,0,12,0"
            Padding="0">
            <StackPanel
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Orientation="Vertical">
                <TextBlock
                    Margin="20,8,0,8"
                    Style="{DynamicResource BodyTextBlockStyle}"
                    Text="Palettes" />
                <Border
                    Margin="0,0,0,16"
                    Padding="0,4,4,4"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    CornerRadius="8">
                    <ListBox
                        x:Name="paletteListBox"
                        MinWidth="272"
                        MinHeight="256"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="Transparent"
                        FocusVisualStyle="{x:Null}"
                        ItemContainerStyle="{DynamicResource listPaletteRowStyle}"
                        ItemsSource="{Binding Palette.PaletteRows}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        SelectedIndex="{Binding CgxViewer.Palette.SelectedPaletteRowIndex, Mode=TwoWay}">

                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PaletteRowViewModel}">
                                <!--  One row of 16 colours  -->
                                <ItemsControl ItemsSource="{Binding Colors}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <!--  One swatch  -->
                                            <uc:Swatch
                                                Width="16"
                                                Height="16"
                                                Background="{Binding RgbColorBrush}"
                                                IsHitTestVisible="True"
                                                RGBColorHex="{Binding RGBColorString}"
                                                SnesColorValue="{Binding SnesColorString}" />

                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </Border>

                <Button
                    x:Name="btnDisplayHex"
                    Margin="4,0,0,16"
                    Command="{Binding ShowColHexCommand}"
                    Content="Display COL raw hex"
                    IsEnabled="{Binding HasCol}" />

                <CheckBox
                    x:Name="rowSelectCheck"
                    Margin="4,0,0,8"
                    Content="Force single palette row"
                    IsChecked="{Binding CgxViewer.Palette.ForceSingleRow}"
                    IsEnabled="{Binding CgxViewer.Palette.ForceSingleRowEnabled}" />

                <TextBlock
                    x:Name="txtValidity"
                    Margin="4,4,0,8"
                    HorizontalAlignment="Left"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                    Text="All colours within valid SNES range"
                    TextAlignment="Left"
                    Visibility="Collapsed" />

                <TextBlock
                    x:Name="txtMalformed"
                    MaxWidth="256"
                    Margin="4,4,0,8"
                    HorizontalAlignment="Left"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                    Text="This COL file is malformed"
                    TextAlignment="Left"
                    TextWrapping="WrapWithOverflow"
                    Visibility="Collapsed" />


            </StackPanel>
        </ScrollViewer>

        <!--  For resizing the tabebd column  -->
        <GridSplitter
            Grid.Row="1"
            Grid.Column="2"
            Width="4"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch" />

        <Grid
            Grid.Row="1"
            Grid.Column="3"
            Margin="8,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Left"
                helpers:DpiScaleHelper.Maintain100PercentScale="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                Source="{Binding CgxViewer.Spacer}"
                Stretch="None" />

            <Image
                x:Name="columnsImage"
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Left"
                helpers:DpiScaleHelper.Maintain100PercentScale="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                Source="{Binding CgxViewer.ColumnHeader}"
                Stretch="None" />

            <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2">
                <Grid
                    Margin="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Image
                        x:Name="rowsImage"
                        Grid.Column="0"
                        VerticalAlignment="Top"
                        helpers:DpiScaleHelper.Maintain100PercentScale="True"
                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                        SnapsToDevicePixels="True"
                        Source="{Binding CgxViewer.RowHeader}"
                        Stretch="None" />

                    <Image
                        x:Name="cgxImage"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        helpers:DpiScaleHelper.Maintain100PercentScale="True"
                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                        Source="{Binding CgxViewer.CgxBitmap}"
                        Stretch="None" />

                </Grid>
            </ScrollViewer>
        </Grid>



        <!--  SCR, MAP and PNL region  -->
        <TabControl
            Grid.Row="1"
            Grid.Column="2"
            Margin="0,0,16,8">
            <TabItem Header="SCR files" Style="{DynamicResource clearTabs}">
                <Border
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="240" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="240" />
                        </Grid.ColumnDefinitions>

                        <TreeView
                            x:Name="scrTreeView"
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,0,0"
                            ItemsSource="{Binding ScrTree.RootItems}"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItemChanged="scrTreeView_SelectedItemChanged">

                            <TreeView.Resources>

                                <!--  Folder template  -->
                                <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}" ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Name}" />
                                </HierarchicalDataTemplate>

                                <!--  File template  -->
                                <DataTemplate DataType="{x:Type models:FileNode}">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>

                            </TreeView.Resources>
                        </TreeView>

                        <GridSplitter Grid.Column="1" VerticalAlignment="Stretch" />

                        <Border
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="0,8,0,8"
                            Padding="16,0,16,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1,0,0,0">

                            <StackPanel Margin="0,16,0,16" Orientation="Vertical">

                                <TextBlock
                                    x:Name="scrDebugText"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch"
                                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                    Style="{DynamicResource CaptionTextBlockStyle}"
                                    Text="Debug visuals" />

                                <ComboBox
                                    x:Name="scrDebugSelector"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Stretch"
                                    ItemsSource="{Binding ScrViewer.DebugModes}"
                                    SelectedItem="{Binding ScrViewer.SelectedDebugMode}" />

                                <CheckBox
                                    x:Name="chkShowInvisible"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Stretch"
                                    Content="Show invisible tiles"
                                    IsChecked="{Binding ScrViewer.ShowInvisibleTiles, Mode=TwoWay}" />


                                <TextBlock
                                    x:Name="scrZoomText"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                    Style="{DynamicResource CaptionTextBlockStyle}"
                                    Text="SCR Zoom" />

                                <ComboBox
                                    x:Name="scrZoomSelector"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Stretch"
                                    DataContext="{Binding ScrViewer}"
                                    SelectedValue="{Binding ZoomLevel, Mode=TwoWay}"
                                    SelectedValuePath="Tag">

                                    <ComboBoxItem Content="100%" Tag="1" />
                                    <ComboBoxItem Content="200%" Tag="2" />
                                    <ComboBoxItem Content="300%" Tag="3" />
                                    <ComboBoxItem Content="400%" Tag="4" />

                                </ComboBox>

                            </StackPanel>

                        </Border>

                        <Border
                            Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Height="1"
                            Margin="16,0,16,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />


                        <ScrollViewer
                            Grid.Row="2"
                            Grid.ColumnSpan="3"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                            <Image
                                x:Name="scrImage"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                helpers:DpiScaleHelper.Maintain100PercentScale="True"
                                RenderOptions.BitmapScalingMode="NearestNeighbor"
                                Source="{Binding ScrViewer.Bitmap}"
                                Stretch="None"
                                UseLayoutRounding="True" />
                        </ScrollViewer>


                    </Grid>
                </Border>
            </TabItem>


            <TabItem Header="MAP and PNL files" Style="{DynamicResource clearTabs}">
                <Border
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="240" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <TreeView
                            x:Name="pnlTreeView"
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,0,0"
                            ItemsSource="{Binding PnlTree.RootItems}"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItemChanged="pnlTreeView_SelectedItemChanged">

                            <TreeView.Resources>

                                <!--  Folder template  -->
                                <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}" ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Name}" />
                                </HierarchicalDataTemplate>

                                <!--  File template  -->
                                <DataTemplate DataType="{x:Type models:FileNode}">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>

                            </TreeView.Resources>
                        </TreeView>


                        <TreeView
                            x:Name="mapTreeView"
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="0,0,0,0"
                            ItemsSource="{Binding MapTree.RootItems}"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItemChanged="mapTreeView_SelectedItemChanged">

                            <TreeView.Resources>

                                <!--  Folder template  -->
                                <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}" ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Name}" />
                                </HierarchicalDataTemplate>

                                <!--  File template  -->
                                <DataTemplate DataType="{x:Type models:FileNode}">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>

                            </TreeView.Resources>
                        </TreeView>


                        <Border
                            Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Height="1"
                            Margin="16,4,16,3"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

                        <Border
                            Grid.RowSpan="1"
                            Grid.Column="1"
                            Width="1"
                            Margin="4,16,3,16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch"
                            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />


                        <!--  PNL Viewer  -->

                        <ScrollViewer
                            Grid.Row="2"
                            Grid.ColumnSpan="3"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                            <Image
                                x:Name="pnlImage"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                helpers:DpiScaleHelper.Maintain100PercentScale="True"
                                RenderOptions.BitmapScalingMode="NearestNeighbor"
                                Source="{Binding MapPnlViewer.Bitmap}"
                                Stretch="None"
                                UseLayoutRounding="True" />
                        </ScrollViewer>

                        <!--  Switch view  -->
                        <ComboBox
                            x:Name="pnlSwitchSelector"
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="12,8,12,8"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{Binding MapPnlViewer.AvailableModes}"
                            SelectedValue="{Binding MapPnlViewer.RenderMode, Mode=TwoWay}"
                            SelectedValuePath="Mode">

                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>




                        <!--  Zoom  -->

                        <StackPanel
                            Grid.Row="3"
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">

                            <TextBlock
                                Margin="0,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Style="{DynamicResource CaptionTextBlockStyle}"
                                Text="MAP/PNL Zoom"
                                TextAlignment="Right" />

                            <ComboBox
                                x:Name="pnlZoomSelector"
                                Width="120"
                                Margin="12,8,12,8"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                DataContext="{Binding MapPnlViewer}"
                                SelectedValue="{Binding ZoomLevel, Mode=TwoWay}"
                                SelectedValuePath="Tag">

                                <ComboBoxItem Content="100%" Tag="1" />
                                <ComboBoxItem Content="200%" Tag="2" />
                                <ComboBoxItem Content="300%" Tag="3" />
                                <ComboBoxItem Content="400%" Tag="4" />

                            </ComboBox>
                        </StackPanel>

                    </Grid>
                </Border>
            </TabItem>

        </TabControl>



        <!--  Status Bar Row  -->
        <Border
            Grid.Row="2"
            Grid.ColumnSpan="4"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        x:Name="txtStatus"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Style="{DynamicResource CaptionTextBlockStyle}"
                        Text="{Binding SelectedFolder}" />
                </StackPanel>



                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <TextBlock
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Style="{DynamicResource CaptionTextBlockStyle}"
                        Text="CGX Zoom"
                        TextAlignment="Right" />

                    <!--  User zoom selector  -->
                    <ComboBox
                        x:Name="cgxZoomSelector"
                        Width="120"
                        Margin="16,8,8,8"
                        HorizontalAlignment="Right"
                        DataContext="{Binding CgxViewer}"
                        SelectedValue="{Binding ZoomLevel, Mode=TwoWay}"
                        SelectedValuePath="Tag">
                        <ComboBoxItem Content="100%" Tag="1" />
                        <ComboBoxItem Content="200%" Tag="2" />
                        <ComboBoxItem Content="300%" Tag="3" />
                        <ComboBoxItem Content="400%" Tag="4" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>

</Window>
